# OS / editor
.DS_Store
.vscode/
.idea/
*.swp

# Python (defensive — prototype/ has its own .gitignore too)
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.ipynb_checkpoints/
uv.lock

# Local data — never commit real or generated financial data.
# NOTE: do NOT add a bare `data/` here — it would match prototype/data/,
# which is a Python package. Use file-extension patterns instead.
*.csv
*.parquet


# Leftover archive from earlier zip workflow
prototype.zip
*.zip

# Secrets — defensive even though this repo has none today
.env
.env.local
*.key
*.pem
